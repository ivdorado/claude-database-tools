# SQL Server Connection Settings
SQL_SERVER=localhost
SQL_DATABASE=your_database
SQL_USER=your_username
SQL_PASSWORD=your_password
SQL_PORT=1433

# Authentication type: 'sql' (default, uses SQL_USER/SQL_PASSWORD) or
# 'azure-ad-device-code' for Azure SQL with MFA (device code flow).
# SQL_AUTH_TYPE=azure-ad-device-code
# AZURE_TENANT_ID=your-tenant-id
# AZURE_CLIENT_ID=your-app-registration-client-id

# Connection Options
SQL_ENCRYPT=false
SQL_TRUST_SERVER_CERTIFICATE=true

# Timeouts (in seconds)
CONNECTION_TIMEOUT=30
REQUEST_TIMEOUT=60

# Set to 'true' to restrict to read-only operations
READONLY_MODE=false
